# 复制为 .env 后填入真实值（.env 已在 .gitignore 中，不会提交）
# Windows PowerShell 启动前也可直接：$env:DASHSCOPE_API_KEY="你的密钥"

# 百炼 DashScope（必填，否则问答/向量化不可用）
DASHSCOPE_API_KEY=your-dashscope-api-key

# Docker 本地 MySQL（docker-compose 映射 3307）
MYSQL_PORT=3307
MYSQL_PASSWORD=root

# 可选：模型与中间件
# OPENAI_CHAT_MODEL=qwen-plus
# OPENAI_EMBEDDING_MODEL=text-embedding-v4
# MILVUS_DIM=1024
# REDIS_HOST=localhost
# REDIS_PORT=6379
